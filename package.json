{
  "name": "poly-model-bridge",
  "displayName": "Poly Model Bridge for Copilot",
  "description": "Bring third-party models into GitHub Copilot's model picker over Anthropic Messages, OpenAI Chat Completions, or OpenAI Responses protocols — with per-model reasoning effort variants, tool calling and vision.",
  "version": "0.4.1",
  "publisher": "silver-zhang",
  "author": {
    "name": "Silver-Zhang"
  },
  "license": "MIT",
  "icon": "icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/Silver-Zhang/poly-model-bridge.git"
  },
  "bugs": {
    "url": "https://github.com/Silver-Zhang/poly-model-bridge/issues"
  },
  "homepage": "https://github.com/Silver-Zhang/poly-model-bridge#readme",
  "keywords": [
    "copilot",
    "byok",
    "anthropic",
    "claude",
    "openai",
    "responses",
    "reasoning",
    "effort",
    "proxy",
    "relay",
    "gateway"
  ],
  "engines": {
    "vscode": "^1.106.0"
  },
  "categories": [
    "AI",
    "Chat"
  ],
  "galleryBanner": {
    "color": "#1F1F2E",
    "theme": "dark"
  },
  "pricing": "Free",
  "main": "./extension.js",
  "activationEvents": [],
  "contributes": {
    "languageModelChatProviders": [
      {
        "vendor": "poly-bridge",
        "displayName": "Poly Model Bridge",
        "managementCommand": "polyBridge.manage"
      }
    ],
    "commands": [
      {
        "command": "polyBridge.quickSettings",
        "title": "Poly Model Bridge: Quick Settings (思考工作量 / 上下文)"
      },
      {
        "command": "polyBridge.setApiKey",
        "title": "Poly Model Bridge: Set API Key"
      },
      {
        "command": "polyBridge.addProvider",
        "title": "Poly Model Bridge: Add Provider (中转站)"
      },
      {
        "command": "polyBridge.manage",
        "title": "Poly Model Bridge: Manage Providers (管理中转站)"
      }
    ],
    "configuration": {
      "title": "Poly Model Bridge",
      "properties": {
        "polyBridge.providers": {
          "type": "array",
          "default": [],
          "markdownDescription": "Endpoint providers to bridge into Copilot. Each provider has a protocol (`apiType`), a `baseUrl` and a list of `models`. API keys are stored per provider in SecretStorage via the **Poly Model Bridge: Set API Key** command.",
          "items": {
            "type": "object",
            "required": [
              "name",
              "baseUrl",
              "models"
            ],
            "properties": {
              "name": {
                "type": "string",
                "description": "Unique provider name (used for grouping and API-key storage)"
              },
              "baseUrl": {
                "type": "string",
                "description": "Base URL, e.g. https://my-relay.example.com — protocol path (/v1/messages, /v1/chat/completions, /v1/responses) is appended automatically"
              },
              "apiType": {
                "type": "string",
                "enum": [
                  "anthropic",
                  "chat-completions",
                  "responses"
                ],
                "default": "anthropic",
                "description": "Default wire protocol for this provider's models"
              },
              "authHeader": {
                "type": "string",
                "enum": [
                  "x-api-key",
                  "authorization"
                ],
                "description": "Auth style override. Defaults: anthropic → x-api-key, OpenAI protocols → Authorization: Bearer"
              },
              "requiresApiKey": {
                "type": "boolean",
                "default": true,
                "description": "Set false for endpoints without authentication (e.g. local servers)"
              },
              "extraHeaders": {
                "type": "object",
                "additionalProperties": {
                  "type": "string"
                },
                "description": "Custom HTTP headers attached to every request"
              },
              "models": {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": [
                    "id"
                  ],
                  "properties": {
                    "id": {
                      "type": "string",
                      "description": "Model ID sent to the endpoint"
                    },
                    "name": {
                      "type": "string",
                      "description": "Display name in the model picker (defaults to id)"
                    },
                    "apiType": {
                      "type": "string",
                      "enum": [
                        "anthropic",
                        "chat-completions",
                        "responses"
                      ],
                      "description": "Per-model protocol override"
                    },
                    "efforts": {
                      "type": "array",
                      "items": {
                        "type": "string"
                      },
                      "description": "Reasoning-effort variants, e.g. [\"low\", \"medium\", \"high\"] — one picker entry per effort (Anthropic: output_config.effort; Chat Completions: reasoning_effort; Responses: reasoning.effort)"
                    },
                    "effort": {
                      "type": "string",
                      "description": "Single fixed reasoning effort (no picker suffix); ignored when 'efforts' is set"
                    },
                    "thinking": {
                      "type": "boolean",
                      "default": false,
                      "description": "Anthropic: request adaptive thinking with summarized display; Responses: request reasoning summaries. Thinking deltas stream into the chat UI."
                    },
                    "maxInputTokens": {
                      "type": "number",
                      "default": 200000,
                      "description": "Context window (max input tokens)"
                    },
                    "maxOutputTokens": {
                      "type": "number",
                      "default": 16000,
                      "description": "Max output tokens per response"
                    },
                    "maxTokensField": {
                      "type": "string",
                      "enum": [
                        "max_completion_tokens",
                        "max_tokens"
                      ],
                      "description": "Chat Completions only: which max-tokens field to send (default max_completion_tokens; some older gateways need max_tokens)"
                    },
                    "toolCalling": {
                      "type": "boolean",
                      "default": true,
                      "description": "Whether the model supports tool calling (required for agent mode)"
                    },
                    "vision": {
                      "type": "boolean",
                      "default": true,
                      "description": "Whether the model supports image input"
                    },
                    "url": {
                      "type": "string",
                      "description": "Optional: full endpoint URL for this model only, overriding baseUrl + protocol path"
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "scripts": {
    "package": "vsce package",
    "publish": "vsce publish",
    "publish:openvsx": "ovsx publish"
  },
  "devDependencies": {
    "@vscode/vsce": "^3.0.0",
    "ovsx": "^0.10.0"
  }
}
